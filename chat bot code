def chatbot():
    print("ChatBot: Hola pal! Type 'bye' to exit the chat.")

    while True:
        user = input("You: ").lower()

        if user == "hello buddy" or user == "hi buddy":
            print("ChatBot: Hola, pal! Nice to meet you.")

        elif user == "how is it going":
            print("ChatBot: Great! Thanks for asking. How about you?")

        elif user == "i am fine":
            print("ChatBot: That's good to hear!")

        elif user == "what is your name":
            print("ChatBot: My name is jarvis.")

        elif user == "how were you created":
            print("ChatBot: I was created using Python.")

        elif user == "what can you do":
            print("ChatBot: I can chat with you and answer a few simple questions.")

        elif user == "tell me an intresting movie":
            print("ChatBot: I suggest you to watch  interstellar ")

        elif user == "tell me a joke":
            print("ChatBot: Why do programmers prefer dark mode? Because light attracts bugs!")

        elif user == "what is python":
            print("ChatBot: Python is a popular programming language known for its simplicity.")

        elif user == "thank you":
            print("ChatBot: You're welcome, pal!")

        elif user == "bye":
            print("ChatBot: Goodbye! Have a wonderful day!")
            break

        else:
            print("ChatBot: Sorry, I don't understand that.")

chatbot()
